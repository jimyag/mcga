<Window x:Class="MCGA.FloatingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MCGA"
        Title="MCGA Overlay" Height="300" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        MouseEnter="Window_MouseEnter" MouseLeave="Window_MouseLeave" Loaded="Window_Loaded">
    
    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterBorder" Background="{Binding WindowBackground}" CornerRadius="10" BorderBrush="{Binding BorderBrushColor}" BorderThickness="1" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.18" ShadowDepth="1" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Scrollable content -->
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{Binding HeaderBackground}" CornerRadius="9,9,0,0" Padding="12,9">
                <DockPanel>
                    <TextBlock Text="{Binding HeaderText}" Foreground="White" FontSize="12.5" FontWeight="SemiBold" FontFamily="Consolas" MaxWidth="280" TextTrimming="CharacterEllipsis" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <!-- History View -->
                        <Button Style="{StaticResource IconButtonStyle}" Click="BtnHistory_Click" ToolTip="{Binding HistoryTooltip}" Margin="0,0,6,0">
                            <TextBlock Text="" FontSize="11" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                        <!-- Copy First -->
                        <Button Style="{StaticResource IconButtonStyle}" Click="BtnCopyFirst_Click" ToolTip="{Binding CopyFirstTooltip}">
                            <TextBlock Text="" FontSize="11" FontFamily="Segoe MDL2 Assets"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Scroll Area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,2,0,0">
                <ItemsControl ItemsSource="{Binding Results}" Margin="12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding DataContext.CardBackground, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    BorderBrush="{Binding DataContext.BorderBrushColor, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding ParserName}" Foreground="{Binding DataContext.TextPrimaryBrush, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                        <Button Style="{StaticResource IconButtonStyle}" Foreground="{Binding DataContext.TextPrimaryBrush, RelativeSource={RelativeSource AncestorType=Window}}" HorizontalAlignment="Right" Click="BtnCopyResult_Click" ToolTip="{Binding DataContext.CopyResultTooltip, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Button.Resources>
                                                <!-- Overlay hover over dark/light buttons -->
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#22105660"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="#44105660"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Resources>
                                            <TextBlock Text="" FontSize="11" FontFamily="Segoe MDL2 Assets"/>
                                        </Button>
                                    </DockPanel>
                                    <TextBlock Text="{Binding Parsed}" Foreground="{Binding DataContext.TextPrimaryBrush, RelativeSource={RelativeSource AncestorType=Window}}" TextWrapping="Wrap" FontSize="12.5" Margin="0,6,0,0"/>
                                    <Border Visibility="{Binding Details, Converter={StaticResource NullToVisibilityConverter}}" 
                                            Background="#0A105660" CornerRadius="4" Padding="6" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Details}" FontFamily="Consolas" FontSize="11.5" Foreground="{Binding DataContext.TextSecondaryBrush, RelativeSource={RelativeSource AncestorType=Window}}" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
